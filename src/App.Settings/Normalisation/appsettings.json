{
  "Normalisation": {
    "Settings": {
      "ServiceName": "Normalisation",
      "MaxTitleLength": 100,
      "MaxSummaryWords": 100,
      "MaxKeywords": 300,
      "MaxKeywordTags": 10,
      "MaxLinksPerPage": 1000,

      "AllowableLinkSchemas": [
        "http",
        "https"
      ],

      "Processors": {
        "TitleXPath": ".//title",
        "LinksXPath": ".//a[@href]",
        "DefaultLanguageIso2Code": "en",
        "DefaultLanguageIso3Code": "eng"
      }
    }
  },

  "MetaCache": {
    "Provider": "Memory", //Memory|Redis 
    "Redis": {
      "ConnectionString": ""
    }
  },

  "BlobCache": {
    "Provider": "FileStorage", //FileStorage|BlobStorage
    "FileStorage": {
      "ContainerName": "file-cache",
      "AbsoluteExpiryHours": 24
    },
    "BlobStorage": {
      "ContainerName": "blob-cache",
      "AbsoluteExpiryHours": 24,
      "ConnectionString": ""
    }
  },

  "Requests": {
    "RequestSender": {
      "CacheMinAbsoluteExpiryMinutes": 5,
      "CacheMaxAbsoluteExpiryMinutes": 20,
      "RateLimitGroupKey": "normalisation-group"
    },

    "Provider": "HttpClient",
    "HttpClient": {
      "AllowAutoRedirect": true,
      "MaxAutomaticRedirections": 5,
      "TimeoutSeconds": 10,
      "RetryAfterFallbackMinutes": 5
    }
  }
}