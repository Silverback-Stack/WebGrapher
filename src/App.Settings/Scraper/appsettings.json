{
  "Scraper": {
    "Settings": {
      "ServiceName": "Scraper",
      "ContentMaxBytes": 8388608, //8 Mb

      "SitePolicy": {
        "UserAccepts": "text/plain, text/html",
        "AbsoluteExpiryMinutes": 20
      }
    }
  },

  "MetaCache": {
    "Provider": "Memory", //Memory|Redis
    "Redis": {
      "ConnectionString": ""
    }
  },

  "BlobCache": {
    "Provider": "FileStorage", //FileStorage|BlobStorage
    "FileStorage": {
      "ContainerName": "file-cache",
      "AbsoluteExpiryHours": 24
    },
    "BlobStorage": {
      "ContainerName": "blob-cache",
      "AbsoluteExpiryHours": 24,
      "ConnectionString": ""
    }
  },

  "PolicyCache": {
    "Provider": "Memory", //Memory|Redis
    "Redis": {
      "ConnectionString": ""
    }
  },

  "Requests": {
    "RequestSender": {
      "CacheMinAbsoluteExpiryMinutes": 5,
      "CacheMaxAbsoluteExpiryMinutes": 20,
      "RateLimitGroupKey": "scraper-group"
    },

    "Provider": "HttpClient",
    "HttpClient": {
      "AllowAutoRedirect": true,
      "MaxAutomaticRedirections": 5,
      "TimeoutSeconds": 10,
      "RetryAfterFallbackMinutes": 5
    }
  }

}