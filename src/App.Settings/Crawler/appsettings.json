{
  "Crawler": {
    "Settings": {
      "ServiceName": "Crawler",
      "MaxCrawlAttemptLimit": 3,
      "MaxCrawlDepthLimit": 6,
      "ScheduleCrawlDelayMinSeconds": 1,
      "ScheduleCrawlDelayMaxSeconds": 3,

      "SitePolicy": {
        "UserAccepts": "text/plain, text/html",
        "AbsoluteExpiryMinutes": 20
      }
    }
  },

  "MetaCache": {
    "Container": "meta-cache",
    "Provider": "Memory", //Memory|Redis 

    "Redis": {
      "ConnectionString": ""
    }
  },

  "BlobCache": {
    "Container": "blob-cache",
    "Provider": "FileStorage", //FileStorage|BlobStorage

    "FileStorage": {
      "AbsoluteExpiryHours": 24
    },
    "BlobStorage": {
      "AbsoluteExpiryHours": 24,
      "ConnectionString": ""
    }
  },

  "PolicyCache": {
    "Container": "policy-store",
    "Provider": "Memory", //Memory|Redis

    "Redis": {
      "ConnectionString": ""
    }
  },

  "Requests": {
    "RequestSender": {
      "CacheMinAbsoluteExpiryMinutes": 5,
      "CacheMaxAbsoluteExpiryMinutes": 20,
      "GroupKey": "crawler-group"
    },

    "Provider": "HttpClient",
    "HttpClient": {
      "AllowAutoRedirect": true,
      "MaxAutomaticRedirections": 5,
      "TimeoutSeconds": 10,
      "RetryAfterFallbackMinutes": 5
    }
  }
}